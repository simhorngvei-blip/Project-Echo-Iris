# =============================================================================
# Echo-Iris — Environment Configuration
# Copy this file to .env and adjust values as needed.
# =============================================================================

# --- LLM (Ollama) -----------------------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
OLLAMA_EMBED_MODEL=nomic-embed-text

# --- Short-Term Memory ------------------------------------------------------
STM_MAX_MESSAGES=20

# --- Long-Term Memory -------------------------------------------------------
LTM_TOP_K=3
CHROMA_PERSIST_DIR=./data/chroma_db

# --- Server ------------------------------------------------------------------
HOST=0.0.0.0
PORT=8000

# --- STT (faster-whisper) ----------------------------------------------------
STT_MODEL_SIZE=base
STT_DEVICE=cpu
STT_COMPUTE_TYPE=int8

# --- TTS (ElevenLabs) --------------------------------------------------------
TTS_PROVIDER=elevenlabs
ELEVENLABS_API_KEY=your_key_here
ELEVENLABS_VOICE_ID=your_voice_id
ELEVENLABS_MODEL_ID=eleven_flash_v2_5
TTS_OUTPUT_SAMPLE_RATE=44100
TTS_CHUNK_SIZE=4096

# --- Vision ------------------------------------------------------------------
VISION_ENABLED=true
VISION_YOLO_MODEL=yolov8n.pt
VISION_MIN_CONFIDENCE=0.5
VISION_DEEP_INTERVAL=5.0
VISION_YOLO_TRIGGER_CONF=0.7
VISION_OLLAMA_MODEL=llava

# --- Tools -------------------------------------------------------------------
TOOLS_ENABLED=true
TOOLS_OPEN_APP_ENABLED=true
TOOLS_TIMER_MAX_SECONDS=3600

# --- Sign Language -----------------------------------------------------------
SIGN_LANGUAGE_ENABLED=true
SIGN_LANGUAGE_CONFIDENCE=2.0
SIGN_LANGUAGE_COOLDOWN=3.0
SIGN_LANGUAGE_BUFFER_SIZE=30

# --- Robot -------------------------------------------------------------------
ROBOT_ENABLED=true
ROBOT_PORT=auto
ROBOT_BAUD_RATE=115200
ROBOT_TIMEOUT=1.0
